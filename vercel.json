{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/",
      "has": [
        { "type": "host", "value": "(?<slug>[^.]+)\\.nahlad\\.iskaro\\.sk" }
      ],
      "destination": "/previews/$slug/index.html"
    },
    {
      "source": "/:path+",
      "has": [
        { "type": "host", "value": "(?<slug>[^.]+)\\.nahlad\\.iskaro\\.sk" }
      ],
      "destination": "/previews/$slug/:path+"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ]
}
